DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"
NEXT_PUBLIC_CHECKOUT_RECIPIENT_ADDRESS=

# DueVault is mainnet-only. Local and production Umbra flows both use mainnet USDC.
NEXT_PUBLIC_UMBRA_NETWORK="mainnet"
NEXT_PUBLIC_CHECKOUT_MINT_ID="USDC"
NEXT_PUBLIC_UMBRA_RPC_URL="https://api.mainnet-beta.solana.com"
NEXT_PUBLIC_UMBRA_RPC_SUBSCRIPTIONS_URL="wss://api.mainnet-beta.solana.com"

NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional. Leave unset unless you paste Privy's exact PEM/SPKI verification key.
PRIVY_JWT_VERIFICATION_KEY=

# Required in production for the public Umbra payment submission rate limiter.
# Provision Redis through Vercel Marketplace/Upstash and expose the REST binding.
KV_REST_API_URL=
KV_REST_API_TOKEN=
