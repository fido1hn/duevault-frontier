generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PaymentIntent {
  id                String          @id @default(cuid())
  merchantProfileId String
  merchantProfile   MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  amountAtomic      String
  mint              String
  status            String          @default("active")
  note              String          @default("")
  customerLabel     String?
  expiresAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([merchantProfileId])
  @@index([merchantProfileId, status])
  @@index([status])
}

model User {
  id              String           @id @default(cuid())
  privyDid        String           @unique
  email           String?
  name            String?
  wallets         Wallet[]
  merchantProfile MerchantProfile?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Wallet {
  id                      String            @id @default(cuid())
  userId                  String
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  chain                   String
  address                 String
  walletClientType        String?
  connectorType           String?
  primaryMerchantProfiles MerchantProfile[] @relation("PrimaryMerchantWallet")
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@unique([chain, address])
  @@index([userId])
}

model MerchantProfile {
  id                          String                @id @default(cuid())
  userId                      String                @unique
  user                        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryWalletId             String
  primaryWallet               Wallet                @relation("PrimaryMerchantWallet", fields: [primaryWalletId], references: [id])
  businessName                String
  contactEmail                String
  businessAddress             String
  defaultNotes                String                @default("Thank you for your business. Payment is expected within 30 days.")
  defaultMint                 String                @default("USDC")
  paymentRail                 String                @default("solana")
  privacyRail                 String                @default("umbra")
  umbraNetwork                String                @default("devnet")
  umbraStatus                 String                @default("not_setup")
  umbraRegisteredAt           DateTime?
  umbraWalletAddress          String?
  umbraRegistrationSignatures String[]              @default([])
  umbraLastCheckedAt          DateTime?
  onboardingCompletedAt       DateTime?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  customers                   Customer[]
  invoices                    Invoice[]
  paymentIntents              PaymentIntent[]
  umbraInvoicePayments        UmbraInvoicePayment[]

  @@index([contactEmail])
  @@index([primaryWalletId])
  @@index([umbraStatus])
  @@index([umbraWalletAddress])
}

model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  company   String?
  useCase   String?
  source    String   @default("homepage")
  status    String   @default("joined")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([status])
  @@index([createdAt])
}

model Customer {
  id                String          @id @default(cuid())
  merchantProfileId String
  merchantProfile   MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  name              String
  email             String
  invoices          Invoice[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([merchantProfileId, email])
  @@index([merchantProfileId])
}

model Invoice {
  id                String                @id @default(cuid())
  publicId          String                @unique @default(uuid())
  merchantProfileId String
  merchantProfile   MerchantProfile       @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  invoiceNumber     String
  customerId        String
  customer          Customer              @relation(fields: [customerId], references: [id])
  customerName      String
  customerEmail     String
  status            String                @default("Draft")
  issuedAt          DateTime
  dueAt             DateTime
  notes             String                @default("")
  paymentRail       String                @default("solana")
  privacyRail       String                @default("umbra")
  mint              String                @default("USDC")
  totalAmountAtomic String
  lineItems         InvoiceLineItem[]
  umbraPayments     UmbraInvoicePayment[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([merchantProfileId, invoiceNumber])
  @@index([merchantProfileId])
  @@index([merchantProfileId, dueAt])
  @@index([merchantProfileId, status])
  @@index([customerEmail])
  @@index([dueAt])
  @@index([status])
}

model InvoiceLineItem {
  id               String   @id @default(cuid())
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description      String
  quantity         Int
  unitAmountAtomic String
  sortOrder        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([invoiceId])
}

model UmbraInvoicePayment {
  id                          String          @id @default(cuid())
  invoiceId                   String
  invoice                     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  merchantProfileId           String
  merchantProfile             MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  payerWalletAddress          String
  merchantUmbraWalletAddress  String
  network                     String
  mint                        String
  amountAtomic                String
  status                      String          @default("submitted")
  optionalData                String
  closeProofAccountSignature  String?
  createProofAccountSignature String
  createUtxoSignature         String          @unique
  error                       String?
  confirmedAt                 DateTime?
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  @@index([invoiceId])
  @@index([merchantProfileId])
  @@index([invoiceId, status])
  @@index([payerWalletAddress])
}
